{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acca.frontier_context_packet.v0.1",
  "title": "ACCA Frontier Context Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_version",
    "packet_mode",
    "role",
    "query",
    "answerability",
    "instruction",
    "evidence",
    "exposure_summary",
    "context_budget",
    "constraints",
    "rejected_evidence_summary",
    "route_trace"
  ],
  "properties": {
    "packet_version": {
      "type": "string",
      "const": "acca.frontier_context_packet.v0.1"
    },
    "packet_mode": {
      "type": "string",
      "enum": [
        "compact_default",
        "proof_lite",
        "contradiction_aware",
        "abstain_notice"
      ]
    },
    "role": {
      "type": "string",
      "const": "frontier_model_context_packet"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string"
    },
    "answerability": {
      "type": "string",
      "enum": [
        "answerable_with_context",
        "no_context_needed",
        "abstain_no_authoritative_evidence"
      ]
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "exposure_summary": {
      "$ref": "#/$defs/exposure_summary"
    },
    "context_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_evidence_items",
        "selected_evidence_items",
        "frontier_packet_tokens",
        "tokens_avoided",
        "overflow_policy"
      ],
      "properties": {
        "max_evidence_items": {
          "type": "integer",
          "minimum": 0
        },
        "selected_evidence_items": {
          "type": "integer",
          "minimum": 0
        },
        "frontier_packet_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "tokens_avoided": {
          "type": "integer",
          "minimum": 0
        },
        "overflow_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rejected_evidence_summary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rejected_item"
      }
    },
    "route_trace": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_\\-]*$",
      "minLength": 1,
      "maxLength": 160
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_family",
        "authority",
        "staleness",
        "safety_label",
        "taint_labels",
        "exposure_policy",
        "text_policy",
        "tags",
        "provenance",
        "conflicts_with",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "source_family": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        },
        "staleness": {
          "type": "string"
        },
        "safety_label": {
          "type": "string"
        },
        "taint_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exposure_policy": {
          "type": "string",
          "enum": [
            "frontier_ok",
            "contrastive_ok",
            "metadata_only",
            "forbidden"
          ]
        },
        "text_policy": {
          "type": "string",
          "enum": [
            "verbatim_excerpt",
            "truncated_excerpt",
            "masked"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provenance": {
          "type": "object"
        },
        "conflicts_with": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "text": {
          "type": "string"
        }
      }
    },
    "rejected_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reason"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "rejection_gate": {
          "type": "string",
          "minLength": 1
        },
        "safety_label": {
          "type": "string"
        },
        "taint_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exposure_policy": {
          "type": "string"
        }
      }
    },
    "exposure_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_exposure_policies",
        "selected_taint_labels",
        "forbidden_selected",
        "masked_selected"
      ],
      "properties": {
        "selected_exposure_policies": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "selected_taint_labels": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "forbidden_selected": {
          "type": "integer",
          "minimum": 0
        },
        "masked_selected": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
